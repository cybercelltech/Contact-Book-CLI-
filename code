contacts = {}
numbers = set()

while True:
    print("\n1.Add  2.Search  3.Update  4.Delete  5.Exit")
    choice = input("Enter choice: ")

    if choice == "1":
        name = input("Name: ")
        phone = input("Phone: ")

        if phone in numbers:
            print("Duplicate number!")
        else:
            contacts[name] = phone
            numbers.add(phone)
            print("Contact added.")

    elif choice == "2":
        name = input("Enter name: ")
        print(contacts.get(name, "Contact not found"))

    elif choice == "3":
        name = input("Enter name: ")

        if name in contacts:
            new_phone = input("New phone: ")

            if new_phone in numbers:
                print("Duplicate number!")
            else:
                numbers.remove(contacts[name])
                contacts[name] = new_phone
                numbers.add(new_phone)
                print("Contact updated.")
        else:
            print("Contact not found.")

    elif choice == "4":
        name = input("Enter name: ")

        if name in contacts:
            numbers.remove(contacts[name])
            del contacts[name]
            print("Contact deleted.")
        else:
            print("Contact not found.")

    elif choice == "5":
        break

    else:
        print("Invalid choice!")
